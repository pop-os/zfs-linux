+])
+
+AC_DEFUN([ZFS_AC_KERNEL_FILELOCK_HEADER], [
+	AC_MSG_CHECKING([for standalone filelock header])
+	ZFS_LINUX_TEST_RESULT([filelock_header], [
+		AC_MSG_RESULT(yes)
+		AC_DEFINE(HAVE_FILELOCK_HEADER, 1, [linux/filelock.h exists])
+	], [
+		AC_MSG_RESULT(no)
+	])
+])
